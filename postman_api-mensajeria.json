              { "key": "Accept", "value": "application/json" },
              { "key": "apikey", "value": "{{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/call/fake",
              "host": ["{{base_url}}"],
              "path": ["call", "fake"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"51955682576\",\n  \"isVideo\": false,\n  \"callDuration\": 5\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Simula una llamada entrante a un numero de WhatsApp."
